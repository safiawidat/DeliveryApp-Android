<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_start"
    android:paddingStart="@dimen/spacing_16"
    android:paddingEnd="@dimen/spacing_16">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_28"
        android:gravity="center"
        android:text="Create Request"
        android:textColor="@color/bringo_title"
        android:textSize="@dimen/title_text"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="90dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/spacing_20"
            android:paddingBottom="@dimen/spacing_20">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_section_card"
                android:orientation="vertical"
                android:padding="@dimen/spacing_16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Item"
                    android:textColor="@color/bringo_section_title"
                    android:textSize="@dimen/section_title_text"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etItem"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:background="@android:color/transparent"
                    android:hint="Item description"
                    android:paddingStart="@dimen/spacing_12"
                    android:paddingEnd="@dimen/spacing_12"
                    android:textColor="@color/bringo_section_title"
                    android:textColorHint="@color/bringo_section_title"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bringo_divider"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_16"
                    android:text="Pickup"
                    android:textColor="@color/bringo_section_title"
                    android:textSize="@dimen/section_title_text"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etPickLine1"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:background="@android:color/transparent"
                    android:hint="Street + house"
                    android:paddingStart="@dimen/spacing_12"
                    android:paddingEnd="@dimen/spacing_12"
                    android:textColor="@color/bringo_section_title"
                    android:textColorHint="@color/bringo_section_title"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bringo_divider"/>

                <EditText
                    android:id="@+id/etPickCity"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:background="@android:color/transparent"
                    android:hint="City"
                    android:paddingStart="@dimen/spacing_12"
                    android:paddingEnd="@dimen/spacing_12"
                    android:textColor="@color/bringo_section_title"
                    android:textColorHint="@color/bringo_section_title"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bringo_divider"/>

                <EditText
                    android:id="@+id/etPickPostal"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:background="@android:color/transparent"
                    android:hint="Postal (optional)"
                    android:paddingStart="@dimen/spacing_12"
                    android:paddingEnd="@dimen/spacing_12"
                    android:textColor="@color/bringo_section_title"
                    android:textColorHint="@color/bringo_section_title"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_16"
                    android:text="Pickup simulation location"
                    android:textColor="@color/bringo_section_title"
                    android:textSize="@dimen/body_text"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etPickX"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="X (0-50)"
                        android:inputType="numberDecimal"
                        android:paddingStart="@dimen/spacing_12"
                        android:paddingEnd="@dimen/spacing_12"
                        android:textColor="@color/bringo_section_title"
                        android:textColorHint="@color/bringo_section_title"/>

                    <EditText
                        android:id="@+id/etPickY"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginStart="@dimen/spacing_12"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Y (0-50)"
                        android:inputType="numberDecimal"
                        android:paddingStart="@dimen/spacing_12"
                        android:paddingEnd="@dimen/spacing_12"
                        android:textColor="@color/bringo_section_title"
                        android:textColorHint="@color/bringo_section_title"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="@dimen/spacing_16"
                    android:background="@color/bringo_divider"/>

                <CheckBox
                    android:id="@+id/cbUseDefaultDelivery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:text="Use my default delivery address"
                    android:textColor="@color/bringo_section_title"/>

                <LinearLayout
                    android:id="@+id/boxDelivery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="@dimen/spacing_12">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivery"
                        android:textColor="@color/bringo_section_title"
                        android:textSize="@dimen/section_title_text"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/etDelLine1"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:background="@android:color/transparent"
                        android:hint="Street + house"
                        android:paddingStart="@dimen/spacing_12"
                        android:paddingEnd="@dimen/spacing_12"
                        android:textColor="@color/bringo_section_title"
                        android:textColorHint="@color/bringo_section_title"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/bringo_divider"/>

                    <EditText
                        android:id="@+id/etDelCity"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:background="@android:color/transparent"
                        android:hint="City"
                        android:paddingStart="@dimen/spacing_12"
                        android:paddingEnd="@dimen/spacing_12"
                        android:textColor="@color/bringo_section_title"
                        android:textColorHint="@color/bringo_section_title"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/bringo_divider"/>

                    <EditText
                        android:id="@+id/etDelPostal"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:background="@android:color/transparent"
                        android:hint="Postal (optional)"
                        android:paddingStart="@dimen/spacing_12"
                        android:paddingEnd="@dimen/spacing_12"
                        android:textColor="@color/bringo_section_title"
                        android:textColorHint="@color/bringo_section_title"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_16"
                        android:text="Delivery simulation location"
                        android:textColor="@color/bringo_section_title"
                        android:textSize="@dimen/body_text"
                        android:textStyle="bold"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_12"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etDelX"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/button_height"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="X (0-50)"
                            android:inputType="numberDecimal"
                            android:paddingStart="@dimen/spacing_12"
                            android:paddingEnd="@dimen/spacing_12"
                            android:textColor="@color/bringo_section_title"
                            android:textColorHint="@color/bringo_section_title"/>

                        <EditText
                            android:id="@+id/etDelY"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/button_height"
                            android:layout_marginStart="@dimen/spacing_12"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="Y (0-50)"
                            android:inputType="numberDecimal"
                            android:paddingStart="@dimen/spacing_12"
                            android:paddingEnd="@dimen/spacing_12"
                            android:textColor="@color/bringo_section_title"
                            android:textColorHint="@color/bringo_section_title"/>
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btnContinue"
                    style="@style/BrinGoButtonPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_16"
                    android:text="Continue to checkout"/>

                <Button
                    android:id="@+id/btnBack"
                    style="@style/BrinGoButtonOutline"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:text="Back"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
