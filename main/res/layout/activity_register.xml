<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_start"
    android:paddingStart="@dimen/spacing_16"
    android:paddingEnd="@dimen/spacing_16">

    <!-- Logo -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="@dimen/logo_size"
        android:layout_height="@dimen/logo_size"
        android:layout_marginTop="@dimen/spacing_28"
        android:contentDescription="@string/app_name"
        android:src="@drawable/ic_launcher_foreground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- BrinGo title -->
    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_12"
        android:gravity="center"
        android:maxWidth="@dimen/title_max_width"
        android:text="@string/app_name"
        android:textColor="@color/bringo_title"
        android:textSize="@dimen/title_text"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/ivLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Subtitle (Java changes this to Register Customer/Carrier) -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_6"
        android:gravity="center"
        android:text="Register"
        android:textColor="@color/bringo_subtitle"
        android:textSize="@dimen/subtitle_text"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/spacing_20"
        android:background="@color/bringo_divider"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Scroll container for many fields -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/spacing_20"
            android:paddingBottom="@dimen/spacing_20">

            <!-- Register card -->
            <LinearLayout
                android:id="@+id/boxRegister"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_section_card"
                android:orientation="vertical"
                android:padding="@dimen/spacing_16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register"
                    android:textColor="@color/bringo_section_title"
                    android:textSize="@dimen/section_title_text"
                    android:textStyle="bold"/>

                <!-- Full Name -->
                <EditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:background="@android:color/transparent"
                    android:hint="Full name"
                    android:inputType="textPersonName"
                    android:paddingStart="@dimen/spacing_12"
                    android:paddingEnd="@dimen/spacing_12"
                    android:textColor="@color/bringo_section_title"
                    android:textColorHint="@color/bringo_section_title"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bringo_divider"/>

                <!-- Email -->
                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:background="@android:color/transparent"
                    android:hint="Email"
                    android:inputType="textEmailAddress"
                    android:paddingStart="@dimen/spacing_12"
                    android:paddingEnd="@dimen/spacing_12"
                    android:textColor="@color/bringo_section_title"
                    android:textColorHint="@color/bringo_section_title"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bringo_divider"/>

                <!-- Password -->
                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:background="@android:color/transparent"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:paddingStart="@dimen/spacing_12"
                    android:paddingEnd="@dimen/spacing_12"
                    android:textColor="@color/bringo_section_title"
                    android:textColorHint="@color/bringo_section_title"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bringo_divider"/>

                <!-- Phone -->
                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:background="@android:color/transparent"
                    android:hint="Phone number"
                    android:inputType="phone"
                    android:paddingStart="@dimen/spacing_12"
                    android:paddingEnd="@dimen/spacing_12"
                    android:textColor="@color/bringo_section_title"
                    android:textColorHint="@color/bringo_section_title"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bringo_divider"/>

                <!-- ID number -->
                <EditText
                    android:id="@+id/etIdNumber"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:background="@android:color/transparent"
                    android:hint="ID number"
                    android:inputType="number"
                    android:paddingStart="@dimen/spacing_12"
                    android:paddingEnd="@dimen/spacing_12"
                    android:textColor="@color/bringo_section_title"
                    android:textColorHint="@color/bringo_section_title"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bringo_divider"/>

                <!-- Car plate (Carrier only; Java hides this for USER) -->
                <EditText
                    android:id="@+id/etCarPlate"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:background="@android:color/transparent"
                    android:hint="Car plate number"
                    android:inputType="textCapCharacters"
                    android:paddingStart="@dimen/spacing_12"
                    android:paddingEnd="@dimen/spacing_12"
                    android:textColor="@color/bringo_section_title"
                    android:textColorHint="@color/bringo_section_title"/>

                <!-- (optional) divider after car plate, so we can hide it too if you want -->
                <View
                    android:id="@+id/divAfterCarPlate"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bringo_divider"/>

                <!-- Address title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_16"
                    android:text="Address"
                    android:textColor="@color/bringo_section_title"
                    android:textSize="@dimen/body_text"
                    android:textStyle="bold"/>

                <!-- City -->
                <EditText
                    android:id="@+id/etCity"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:background="@android:color/transparent"
                    android:hint="City"
                    android:inputType="textCapWords"
                    android:paddingStart="@dimen/spacing_12"
                    android:paddingEnd="@dimen/spacing_12"
                    android:textColor="@color/bringo_section_title"
                    android:textColorHint="@color/bringo_section_title"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bringo_divider"/>

                <!-- Street -->
                <EditText
                    android:id="@+id/etStreet"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:background="@android:color/transparent"
                    android:hint="Street"
                    android:inputType="textCapWords"
                    android:paddingStart="@dimen/spacing_12"
                    android:paddingEnd="@dimen/spacing_12"
                    android:textColor="@color/bringo_section_title"
                    android:textColorHint="@color/bringo_section_title"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bringo_divider"/>

                <!-- Location simulation -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_16"
                    android:text="Simulation location"
                    android:textColor="@color/bringo_section_title"
                    android:textSize="@dimen/body_text"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etLocX"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="X (0-50)"
                        android:inputType="number"
                        android:paddingStart="@dimen/spacing_12"
                        android:paddingEnd="@dimen/spacing_12"
                        android:textColor="@color/bringo_section_title"
                        android:textColorHint="@color/bringo_section_title"/>

                    <EditText
                        android:id="@+id/etLocY"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginStart="@dimen/spacing_12"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="Y (0-50)"
                        android:inputType="number"
                        android:paddingStart="@dimen/spacing_12"
                        android:paddingEnd="@dimen/spacing_12"
                        android:textColor="@color/bringo_section_title"
                        android:textColorHint="@color/bringo_section_title"/>
                </LinearLayout>

                <!-- Buttons -->
                <Button
                    android:id="@+id/btnRegister"
                    style="@style/BrinGoButtonPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_16"
                    android:text="@string/register"/>

                <Button
                    android:id="@+id/btnBackMain"
                    style="@style/BrinGoButtonOutline"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_12"
                    android:text="Back to main menu"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
